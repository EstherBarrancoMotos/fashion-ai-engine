# =============================================================
# Data: never commit raw or processed data
# =============================================================
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Train/test splits are large, keep them out of git
data/train/*.parquet
data/test/*.parquet
!data/train/.gitkeep
!data/test/.gitkeep

# =============================================================
# MLflow tracking
# =============================================================
mlruns/

# =============================================================
# Python
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================
# Virtual environments
# =============================================================
venv/
env/
ENV/
.venv/

# =============================================================
# Jupyter
# =============================================================
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# =============================================================
# IDE
# =============================================================
.vscode/
.idea/
*.swp
*.swo

# =============================================================
# OS
# =============================================================
.DS_Store
Thumbs.db

# =============================================================
# Models: LARGE artifacts ignored, but final_model.pkl tracked
# =============================================================
# Large saved subfolders (if any)
models/saved/
# We DO track .pkl files in models/ root (brief requires them)
# *.pkl  <- intentionally NOT global

# =============================================================
# Logs
# =============================================================
*.log
logs/

# =============================================================
# Streamlit
# =============================================================
.streamlit/secrets.toml

# =============================================================
# Environment variables
# =============================================================
.env
.env.local

# =============================================================
# Reports: track CSV/JSON results, ignore parquet (large)
# =============================================================
reports/results/*.parquet

# =============================================================
# Kaggle
# =============================================================
kaggle.json

# Streamlit app data dependencies (small parquets needed by deployed app)
!data/processed/simulator_pnl_summary.parquet
!data/processed/simulator_sensitivity.parquet
!data/processed/simulator_per_article.parquet
!data/processed/simulator_top20_reassign.parquet
!data/processed/article_clusters.parquet
!data/processed/article_features.parquet
